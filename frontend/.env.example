# SavdoPRO frontend build configuration.
#
# DESKTOP build: leave everything unset (same-origin + localhost license).
#
# HOSTED WEB (merchant portal) build: copy to `.env.production` (or pass at
# build time) and fill in your real origins.

# Marks the hosted web build (enables web-only behaviour, disables hardware/POS).
VITE_TARGET=web

# Data API origin. Omit/leave blank if the API is served from the SAME origin
# as the SPA (recommended single-origin deploy). Set only for a split host.
# VITE_API_URL=https://app.savdopro.uz

# Central License Server origin (login / accounts / subscriptions).
VITE_LICENSE_URL=https://auth.savdopro.uz
